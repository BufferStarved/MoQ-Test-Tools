{
  "name": "@moqt/browser",
  "version": "0.5.3",
  "description": "Browser adapters for @moqt/player: WebCodecs decoding, Canvas and WebAudio rendering, and MSE/CMAF playback, implementing the player's swappable interfaces.",
  "license": "Apache-2.0",
  "author": "OpenMOQ (https://github.com/openmoq)",
  "contributors": [
    "Raymond Lucke <ray@raylucke.com>"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./browser": {
      "import": "./dist/browser/index.js",
      "default": "./dist/browser/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "moq",
    "media-over-quic",
    "moqt",
    "quic",
    "streaming",
    "low-latency",
    "live-video",
    "browser",
    "webcodecs",
    "mse",
    "cmaf",
    "adapters"
  ],
  "homepage": "https://github.com/openmoq/moq-playa/tree/main/packages/browser#readme",
  "bugs": {
    "url": "https://github.com/openmoq/moq-playa/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openmoq/moq-playa.git",
    "directory": "packages/browser"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@moqt/playback": "file:../playback",
    "@moqt/player": "file:../player",
    "@moqt/webtransport": "file:../webtransport",
    "@moqt/loc": "file:../loc"
  },
  "scripts": {
    "build": "tsc && tsup",
    "build:browser": "tsup"
  }
}
