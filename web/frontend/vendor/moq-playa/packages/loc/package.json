{
  "name": "@moqt/loc",
  "version": "0.5.3",
  "description": "Low Overhead Media Container (LOC) codec for Media over QUIC (MoQ): parses and builds LOC header extensions and yields WebCodecs-ready media chunks.",
  "license": "Apache-2.0",
  "author": "OpenMOQ (https://github.com/openmoq)",
  "contributors": [
    "Raymond Lucke <ray@raylucke.com>"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./browser": {
      "import": "./dist/browser/index.js",
      "default": "./dist/browser/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "moq",
    "media-over-quic",
    "moqt",
    "quic",
    "streaming",
    "low-latency",
    "live-video",
    "loc",
    "container",
    "webcodecs"
  ],
  "homepage": "https://github.com/openmoq/moq-playa/tree/main/packages/loc#readme",
  "bugs": {
    "url": "https://github.com/openmoq/moq-playa/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openmoq/moq-playa.git",
    "directory": "packages/loc"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@moqt/transport": "file:../transport"
  },
  "scripts": {
    "build": "tsc && tsup",
    "build:browser": "tsup"
  }
}
