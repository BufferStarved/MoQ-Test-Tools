{
  "name": "@moqt/msf",
  "version": "0.5.3",
  "description": "Media over QUIC Streaming Format (MSF) catalog: JSON catalog parsing, validation, track selection and ABR, delta updates, and timeline parsing.",
  "license": "Apache-2.0",
  "author": "OpenMOQ (https://github.com/openmoq)",
  "contributors": [
    "Raymond Lucke <ray@raylucke.com>"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./browser": {
      "import": "./dist/browser/index.js",
      "default": "./dist/browser/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "moq",
    "media-over-quic",
    "moqt",
    "quic",
    "streaming",
    "low-latency",
    "live-video",
    "msf",
    "catalog",
    "abr"
  ],
  "homepage": "https://github.com/openmoq/moq-playa/tree/main/packages/msf#readme",
  "bugs": {
    "url": "https://github.com/openmoq/moq-playa/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openmoq/moq-playa.git",
    "directory": "packages/msf"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && tsup",
    "build:browser": "tsup"
  },
  "dependencies": {
    "fast-json-patch": "^3.1.1"
  }
}
