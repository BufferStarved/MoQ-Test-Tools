{
  "name": "@moqt/player",
  "version": "0.5.3",
  "description": "Convenience facade for Media over QUIC (MoQ) playback: wires the sans-I/O core packages into a simple load()/play()/pause()/destroy() API.",
  "license": "Apache-2.0",
  "author": "OpenMOQ (https://github.com/openmoq)",
  "contributors": [
    "Raymond Lucke <ray@raylucke.com>"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./browser": {
      "import": "./dist/browser/index.js",
      "default": "./dist/browser/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "moq",
    "media-over-quic",
    "moqt",
    "quic",
    "streaming",
    "low-latency",
    "live-video",
    "player",
    "webcodecs",
    "webtransport"
  ],
  "homepage": "https://github.com/openmoq/moq-playa/tree/main/packages/player#readme",
  "bugs": {
    "url": "https://github.com/openmoq/moq-playa/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openmoq/moq-playa.git",
    "directory": "packages/player"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@moqt/transport": "file:../transport",
    "@moqt/webtransport": "file:../webtransport",
    "@moqt/loc": "file:../loc",
    "@moqt/msf": "file:../msf",
    "@moqt/playback": "file:../playback"
  },
  "scripts": {
    "build": "tsc && tsup",
    "build:browser": "tsup"
  }
}
