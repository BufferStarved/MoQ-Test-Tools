# Server-side config for automatic VMAF (users just check a box in the UI).
# GCP ingest worker (Zixi VM — handles Zixi + MoQ relay ingest VMAF):
#   ./scripts/sync-ingest-agent-env.sh
INGEST_AGENT_TOKEN=
INGEST_RECORDING_DIR=/opt/zixi_broadcaster-linux64
INGEST_AGENT_PORT=8090

# Local publisher agent (laptop ffmpeg for true internet-acquisition tests).
# scripts/dev.sh enables this automatically. Do NOT set on the hosted web VM.
# LOCAL_PUBLISHER_ENABLED=1
# LOCAL_PUBLISHER_TOKEN=dev-local-publisher
