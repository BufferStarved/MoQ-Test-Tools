# Copy to terraform.tfvars and fill in your values.
# cp terraform.tfvars.example terraform.tfvars

project_name      = "moq-zixi"
region            = "us-east-1"
instance_type     = "t3.xlarge"
ssh_public_key_path = "~/.ssh/id_rsa.pub"

# Restrict SSH to your IP (find it: curl -s ifconfig.me)
allowed_ssh_cidr = "YOUR.IP.ADDRESS.HERE/32"

# Open ingest for benchmark sources; tighten in production
allowed_ingest_cidr = "0.0.0.0/0"
srt_listen_port     = 2088
